{
  "packages": ["."],
  "npmClient": "yarn",
  "version": "0.1.1",
  "command": {
    "publish": {
      "conventionalCommits": true,
      "changelog": false,
      "gitTagVersion": true,
      "ignoreChanges": [
        "**/*.md",
        "**/node_modules/**",
        "**/dist/**",
        "**/coverage/**",
        "**/test/**"
      ],
      "message": "chore(release): publish %s"
    }
  },
  "changelog": {
    "repo": "aceHubert/testlink-mcp",
    "labels": {
      "feat": ":rocket: New Feature",
      "bug": ":bug: Bug Fix",
      "breaking": ":boom: Breaking Change"
    },
    "cacheDir": ".changelog"
  }
}
